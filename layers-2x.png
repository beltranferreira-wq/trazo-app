<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
<meta name="theme-color" content="#1A1D2E">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="Trazo · En vivo">
<link rel="manifest" href="/manifest.json">
<link rel="apple-touch-icon" href="/icons/icon-180.png">
<link rel="icon" type="image/png" sizes="32x32" href="/icons/favicon-32.png">
<title>Trazo · Seguimiento en vivo</title>
<link rel="stylesheet" href="/vendor/leaflet/leaflet.css">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@600;700&family=Inter:wght@400;500;600;700&family=IBM+Plex+Mono:wght@500&display=swap" rel="stylesheet">
<style>
:root{
  --ink:#15182B; --surface:#fff; --line:#DBE0E8; --muted:#6B7180;
  --paper:#ECF0F5; --dark:#1A1D2E; --dark2:#22263A;
  --accent:#FF5A36; --accent-soft:#FFE6DD;
  --success:#1F9D6F; --success-soft:#DCF1E6;
  --warn:#D14343; --warn-soft:#FBE2E0;
  --amber:#C9871E; --amber-soft:#F8E9CC;
  --safe-t:env(safe-area-inset-top,0px);
  --safe-b:env(safe-area-inset-bottom,0px);
}
*{box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
html,body{margin:0;height:100%;overscroll-behavior:none;overflow:hidden;}
body{font-family:'Inter',sans-serif;color:var(--ink);background:var(--dark);
  -webkit-font-smoothing:antialiased;display:flex;flex-direction:column;}
h1,h2,.product-name{font-family:'Space Grotesk',sans-serif;}
.mono{font-family:'IBM Plex Mono',monospace;}
button{font-family:inherit;cursor:pointer;border:none;}
a{text-decoration:none;}
@media(prefers-reduced-motion:reduce){*{animation-duration:.01ms!important;transition-duration:.01ms!important;}}

/* ── TOP BAR ── */
.topbar{
  display:flex;align-items:center;gap:11px;
  padding:calc(var(--safe-t) + 12px) 16px 12px;
  background:var(--dark);flex-shrink:0;z-index:20;
}
.brand-mark{
  width:34px;height:34px;border-radius:9px;
  background:rgba(255,255,255,0.12);
  display:flex;align-items:center;justify-content:center;flex-shrink:0;
}
.brand-mark svg{width:18px;height:18px;stroke:#fff;stroke-width:2;stroke-linecap:round;stroke-linejoin:round;fill:none;}
.topbar-text{flex:1;min-width:0;}
.topbar-product{font-size:14px;font-weight:700;color:#fff;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;font-family:'Space Grotesk',sans-serif;}
.topbar-sub{font-size:11px;color:rgba(255,255,255,0.45);margin-top:1px;}
.live-chip{
  display:flex;align-items:center;gap:5px;
  font-size:11px;font-weight:700;padding:5px 10px;
  border-radius:20px;white-space:nowrap;flex-shrink:0;
  background:rgba(255,255,255,0.1);color:rgba(255,255,255,0.7);
  transition:background .3s,color .3s;
}
.live-chip .cdot{width:7px;height:7px;border-radius:50%;background:rgba(255,255,255,0.4);}
.live-chip.active{background:var(--accent);color:#fff;}
.live-chip.active .cdot{background:#fff;animation:blink 1.2s ease-in-out infinite;}
.live-chip.delivered{background:var(--success);color:#fff;}
.live-chip.delivered .cdot{background:#fff;animation:none;}
@keyframes blink{0%,100%{opacity:1;}50%{opacity:0.25;}}

/* ── MAP ── */
#liveMap{flex:1;min-height:0;background:var(--dark2);}

/* ── BOTTOM SHEET ── */
.sheet{
  background:var(--surface);
  border-radius:22px 22px 0 0;
  padding:0 18px calc(16px + var(--safe-b));
  flex-shrink:0;
  box-shadow:0 -12px 40px rgba(0,0,0,0.35);
  max-height:56vh;overflow-y:auto;
  -webkit-overflow-scrolling:touch;
  transition:max-height .3s ease;
}
.sheet-handle{width:38px;height:5px;border-radius:3px;background:var(--line);margin:14px auto 0;}

/* ── ETA HERO ── */
.eta-hero{
  display:flex;align-items:center;gap:14px;
  background:var(--ink);color:#fff;
  border-radius:16px;padding:16px;margin-top:16px;
}
.eta-icon{
  width:48px;height:48px;border-radius:13px;
  background:rgba(255,255,255,0.1);
  display:flex;align-items:center;justify-content:center;flex-shrink:0;
}
.eta-icon svg{width:24px;height:24px;stroke:#fff;stroke-width:1.8;stroke-linecap:round;stroke-linejoin:round;fill:none;}
.eta-vals{flex:1;min-width:0;}
.eta-big{font-size:26px;font-weight:700;font-family:'Space Grotesk',sans-serif;letter-spacing:-0.02em;line-height:1.1;}
.eta-arr{font-size:12.5px;color:rgba(255,255,255,0.65);margin-top:3px;}
.eta-km{font-size:11.5px;color:rgba(255,255,255,0.45);margin-top:2px;}

/* ── PRODUCT ROW ── */
.product-row{display:flex;align-items:flex-start;gap:12px;margin-top:14px;}
.product-emo{font-size:32px;line-height:1;flex-shrink:0;}
.product-info{flex:1;min-width:0;}
.product-name{font-size:18px;font-weight:700;letter-spacing:-0.01em;line-height:1.2;}
.product-carrier{font-size:12.5px;color:var(--muted);margin-top:3px;}
.product-code{display:flex;align-items:center;gap:6px;margin-top:6px;}
.product-code span{font-size:12px;color:var(--muted);}

/* ── STATUS ROW ── */
.status-row{
  display:flex;align-items:flex-start;gap:10px;
  background:var(--paper);border-radius:12px;padding:12px 13px;margin-top:12px;
}
.sdot{width:9px;height:9px;border-radius:50%;margin-top:3px;flex-shrink:0;}
.sdot.active{background:var(--success);box-shadow:0 0 0 3px var(--success-soft);animation:sp 1.6s ease-in-out infinite;}
.sdot.waiting{background:var(--amber);}
.sdot.delivered{background:var(--success);}
.sdot.offline{background:var(--muted);}
@keyframes sp{0%,100%{box-shadow:0 0 0 3px var(--success-soft);}50%{box-shadow:0 0 0 6px var(--success-soft);}}
.stext b{font-size:13.5px;font-weight:700;display:block;}
.stext small{font-size:11.5px;color:var(--muted);}

/* ── MINI ROUTE ── */
.mini-route{
  display:flex;flex-direction:column;gap:0;
  background:var(--paper);border-radius:12px;padding:12px 14px;margin-top:12px;
}
.mr-row{display:flex;align-items:center;gap:10px;position:relative;}
.mr-row+.mr-row{margin-top:8px;}
.mr-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0;}
.mr-dot.or{background:#9AA3B2;}
.mr-dot.cr{background:var(--accent);}
.mr-dot.dt{background:var(--ink);}
.mr-lbl{font-size:10.5px;color:var(--muted);width:70px;flex-shrink:0;font-weight:600;}
.mr-val{flex:1;font-size:13px;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.mr-val.mono{font-size:11.5px;color:var(--muted);}
.mr-line{position:absolute;left:4px;top:12px;width:2px;height:calc(100% + 8px);background:var(--line);}

/* ── ALERT ── */
.alert-box{
  display:flex;gap:9px;align-items:flex-start;
  background:var(--warn-soft);color:#9A2E2E;
  border-radius:12px;padding:12px 14px;
  font-size:13px;line-height:1.45;margin-top:12px;
}
.alert-box svg{width:17px;height:17px;stroke:var(--warn);flex-shrink:0;margin-top:1px;stroke-width:2;stroke-linecap:round;stroke-linejoin:round;fill:none;}

/* ── COURIER BUTTON ── */
.btn-courier{
  width:100%;margin-top:14px;
  background:var(--ink);color:#fff;
  border:none;border-radius:14px;padding:15px;
  font-size:15px;font-weight:700;
  display:flex;align-items:center;justify-content:center;gap:9px;
  transition:background .2s;
}
.btn-courier svg{width:18px;height:18px;stroke:#fff;stroke-width:2;stroke-linecap:round;stroke-linejoin:round;fill:none;flex-shrink:0;}
.btn-courier.sharing{background:var(--success);}
.btn-courier:active{opacity:0.85;}
.btn-courier:disabled{background:var(--muted);cursor:default;}

/* ── BOTTOM PADDING ── */
.sheet-pad{height:8px;}

/* ── MAP PINS ── */
.pin-or{width:12px;height:12px;border-radius:50%;background:#9AA3B2;border:2.5px solid #fff;box-shadow:0 1px 5px rgba(0,0,0,.4);}
.pin-dt-wrap{display:flex;flex-direction:column;align-items:center;gap:3px;}
.pin-dt{width:16px;height:16px;border-radius:50%;background:var(--ink);border:3px solid #fff;box-shadow:0 2px 8px rgba(0,0,0,.5);}
.pin-dt-lbl{background:var(--ink);color:#fff;font-size:10.5px;font-weight:700;padding:3px 8px;border-radius:20px;white-space:nowrap;box-shadow:0 2px 8px rgba(0,0,0,.3);}
.pin-cw{position:relative;display:flex;align-items:center;justify-content:center;width:24px;height:24px;}
.pin-pulse{position:absolute;width:24px;height:24px;border-radius:50%;background:rgba(255,90,54,0.4);animation:mpp 1.8s ease-out infinite;}
.pin-c{width:14px;height:14px;border-radius:50%;background:var(--accent);border:3px solid #fff;box-shadow:0 2px 6px rgba(0,0,0,.4);z-index:2;}
@keyframes mpp{0%{transform:scale(1);opacity:.7;}100%{transform:scale(3.5);opacity:0;}}

/* ── INVALID SCREEN ── */
.invalid{
  flex:1;display:flex;flex-direction:column;align-items:center;
  justify-content:center;text-align:center;padding:36px 24px;
}
.invalid-icon{font-size:56px;margin-bottom:16px;}
.invalid h2{font-size:20px;font-weight:700;color:#fff;margin:0 0 10px;font-family:'Space Grotesk',sans-serif;}
.invalid p{font-size:14px;color:rgba(255,255,255,0.5);line-height:1.6;margin:0;}

/* ── TOAST ── */
.toast{
  position:fixed;bottom:calc(12px + var(--safe-b));
  left:50%;transform:translateX(-50%) translateY(16px);
  background:var(--ink);color:#fff;
  font-size:13.5px;font-weight:600;
  padding:11px 20px;border-radius:30px;
  opacity:0;pointer-events:none;
  transition:opacity .25s,transform .25s;z-index:500;
  box-shadow:0 8px 24px rgba(0,0,0,.4);
  white-space:nowrap;
}
.toast.on{opacity:1;transform:translateX(-50%) translateY(0);}
</style>
</head>
<body>

<!-- TOP BAR -->
<div class="topbar">
  <div class="brand-mark">
    <svg viewBox="0 0 24 24"><path d="M21 8l-9-5-9 5 9 5 9-5z"/><path d="M3 8v8l9 5 9-5V8"/><path d="M12 13v8"/></svg>
  </div>
  <div class="topbar-text">
    <div class="topbar-product" id="topProduct">Trazo · Seguimiento en vivo</div>
    <div class="topbar-sub" id="topCarrier">Conectando…</div>
  </div>
  <div class="live-chip" id="liveChip">
    <span class="cdot"></span>
    <span id="chipTxt">Sin GPS</span>
  </div>
</div>

<!-- MAP -->
<div id="liveMap"></div>

<!-- BOTTOM SHEET -->
<div class="sheet" id="sheet" style="display:none">
  <div class="sheet-handle"></div>

  <div class="eta-hero" id="etaHero">
    <div class="eta-icon">
      <svg viewBox="0 0 24 24"><rect x="1" y="7" width="13" height="9" rx="1"/><path d="M14 10h4l3 3v3h-7z"/><circle cx="5.5" cy="18" r="1.5"/><circle cx="16.5" cy="18" r="1.5"/></svg>
    </div>
    <div class="eta-vals">
      <div class="eta-big" id="etaBig">Calculando…</div>
      <div class="eta-arr" id="etaArr"></div>
      <div class="eta-km" id="etaKm"></div>
    </div>
  </div>

  <div class="product-row" id="productRow" style="display:none">
    <span class="product-emo" id="prodEmo">📦</span>
    <div class="product-info">
      <div class="product-name" id="prodName">—</div>
      <div class="product-carrier" id="prodCarrier"></div>
      <div class="product-code"><span class="mono" id="prodCode"></span></div>
    </div>
  </div>

  <div class="alert-box" id="alertBox" style="display:none">
    <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg>
    <span id="alertText"></span>
  </div>

  <div class="status-row" id="statusRow">
    <div class="sdot waiting" id="sdot"></div>
    <div class="stext">
      <b id="stextMain">Esperando al transportista…</b>
      <small id="stextSub"></small>
    </div>
  </div>

  <div class="mini-route" id="miniRoute">
    <div class="mr-row" id="mrOr">
      <div class="mr-line"></div>
      <div class="mr-dot or"></div>
      <span class="mr-lbl">Origen</span>
      <span class="mr-val" id="mrOrVal">—</span>
    </div>
    <div class="mr-row" id="mrCr">
      <div class="mr-line"></div>
      <div class="mr-dot cr"></div>
      <span class="mr-lbl">Transportista</span>
      <span class="mr-val mono" id="mrCrVal">Sin señal</span>
    </div>
    <div class="mr-row">
      <div class="mr-dot dt"></div>
      <span class="mr-lbl">Destino</span>
      <span class="mr-val" id="mrDtVal">—</span>
    </div>
  </div>

  <button class="btn-courier" id="courierBtn">
    <svg viewBox="0 0 24 24"><path d="M12 22s-8-6-8-11a8 8 0 1 1 16 0c0 5-8 11-8 11z"/><circle cx="12" cy="11" r="3"/></svg>
    Soy el transportista — Activar GPS
  </button>
  <div class="sheet-pad"></div>
</div>

<!-- INVALID -->
<div class="invalid" id="invalidScreen" style="display:none">
  <div class="invalid-icon">📦</div>
  <h2>Enlace no encontrado</h2>
  <p>Este enlace de seguimiento no existe o ya expiró.<br>Pedile al comercio que te reenvíe el enlace.</p>
</div>

<!-- TOAST -->
<div class="toast" id="toast"></div>

<script src="/vendor/leaflet/leaflet.js"></script>
<script>
'use strict';

// ─── Service Worker ────────────────────────────────────────────────────────
if ('serviceWorker' in navigator) {
  navigator.serviceWorker.register('/sw.js').catch(()=>{});
}

// ─── Params ────────────────────────────────────────────────────────────────
const code = new URLSearchParams(location.search).get('code');

// ─── State ─────────────────────────────────────────────────────────────────
let ws            = null;
let reconnTimer   = null;
let shipment      = null;
let liveMap       = null;
let markers       = {};
let routeLines    = [];
let courierSharing = false;
let watchId       = null;
let lastSend      = 0;
let etaTimer      = null;

// ─── Toast ─────────────────────────────────────────────────────────────────
let toastTimer;
function toast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('on');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(()=>t.classList.remove('on'), 2400);
}

// ─── Utils ─────────────────────────────────────────────────────────────────
function haversine(a, b) {
  const R=6371000, r=d=>d*Math.PI/180;
  const dL=r(b.lat-a.lat), dG=r(b.lng-a.lng);
  const s=Math.sin(dL/2)**2+Math.cos(r(a.lat))*Math.cos(r(b.lat))*Math.sin(dG/2)**2;
  return 2*R*Math.asin(Math.sqrt(s));
}

async function getRoute(from, to) {
  try {
    const ctrl = new AbortController();
    setTimeout(()=>ctrl.abort(), 5000);
    const url = `https://router.project-osrm.org/route/v1/driving/${from.lng},${from.lat};${to.lng},${to.lat}?overview=false&steps=false`;
    const res = await fetch(url, {signal: ctrl.signal});
    const d = await res.json();
    if (d?.routes?.[0]) return { secs: d.routes[0].duration, meters: d.routes[0].distance, real: true };
  } catch(e) {}
  // fallback: straight line at 30 km/h
  const m = haversine(from, to);
  return { secs: (m/1000/30)*3600, meters: m, real: false };
}

function showETA(eta) {
  const mins  = Math.max(1, Math.round(eta.secs/60));
  const arr   = new Date(Date.now() + eta.secs*1000);
  const hh    = String(arr.getHours()).padStart(2,'0');
  const mm    = String(arr.getMinutes()).padStart(2,'0');
  const km    = (eta.meters/1000).toFixed(1);
  const big   = mins<60 ? `~${mins} min` : `~${Math.floor(mins/60)}h ${mins%60}min`;
  document.getElementById('etaBig').textContent = big;
  document.getElementById('etaArr').textContent = `Llegada estimada: ${hh}:${mm} hs`;
  document.getElementById('etaKm').textContent  = `${km} km ${eta.real?'por ruta real (OSRM)':'· distancia directa'}`;
}

function refreshETA() {
  if (!shipment) return;
  const from = (shipment.courierLat && shipment.courierLng)
    ? { lat: shipment.courierLat, lng: shipment.courierLng }
    : (shipment.originLat ? { lat: shipment.originLat, lng: shipment.originLng } : null);
  const to = shipment.destLat ? { lat: shipment.destLat, lng: shipment.destLng } : null;
  if (!from || !to) { document.getElementById('etaBig').textContent = '—'; return; }
  getRoute(from, to).then(showETA);
}

function timeAgo(iso) {
  if (!iso) return '';
  const d = Math.max(0, Date.now()-new Date(iso));
  const m = Math.floor(d/60000);
  if (m<1) return 'ahora';
  if (m<60) return `hace ${m} min`;
  return `hace ${Math.floor(m/60)}h`;
}

// ─── Invalid screen ────────────────────────────────────────────────────────
function showInvalid() {
  document.getElementById('liveMap').style.display = 'none';
  document.getElementById('sheet').style.display = 'none';
  document.getElementById('invalidScreen').style.display = 'flex';
}

if (!code) { showInvalid(); }

// ─── Map ───────────────────────────────────────────────────────────────────
function initMap(s) {
  const el = document.getElementById('liveMap');
  try {
    liveMap = L.map(el, { zoomControl:false, attributionControl:true });
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png',
      { maxZoom:19, attribution:'© <a href="https://www.openstreetmap.org/copyright">OSM</a>' }
    ).addTo(liveMap);
    L.control.zoom({ position:'topright' }).addTo(liveMap);

    if (s.originLat && s.originLng) {
      const mk = L.divIcon({className:'',html:'<div class="pin-or"></div>',iconSize:[12,12],iconAnchor:[6,6]});
      markers.origin = L.marker([s.originLat,s.originLng],{icon:mk}).addTo(liveMap)
        .bindPopup(`📍 ${s.originName||'Origen'}`);
    }
    if (s.destLat && s.destLng) {
      const mk = L.divIcon({className:'',html:`<div class="pin-dt-wrap"><div class="pin-dt-lbl">🏠 ${(s.destName||'Destino').split(',')[0]}</div></div>`,iconAnchor:[0,36]});
      markers.dest = L.marker([s.destLat,s.destLng],{icon:mk}).addTo(liveMap)
        .bindPopup(`🏠 ${s.destName||'Destino'}`);
    }

    // Dashed route
    if (s.originLat && s.destLat) {
      L.polyline([[s.originLat,s.originLng],[s.destLat,s.destLng]],
        {color:'rgba(255,255,255,0.2)',weight:3,dashArray:'3 9'}).addTo(liveMap);
    }

    if (s.courierLat && s.courierLng) {
      placeCourier(s.courierLat, s.courierLng, true);
    }

    fitAll(s);
    setTimeout(()=>{ if(liveMap) liveMap.invalidateSize(); }, 250);
  } catch(e) { console.error('Map init error:', e); }
}

function placeCourier(lat, lng, instant) {
  if (!liveMap) return;
  const mk = L.divIcon({
    className:'',
    html:'<div class="pin-cw"><div class="pin-pulse"></div><div class="pin-c"></div></div>',
    iconSize:[24,24],iconAnchor:[12,12]
  });
  if (!markers.courier) {
    markers.courier = L.marker([lat,lng],{icon:mk,zIndexOffset:1000}).addTo(liveMap)
      .bindPopup('🚚 Transportista');
  } else {
    if (instant) markers.courier.setLatLng([lat,lng]);
    else animateMarker(markers.courier, [lat,lng]);
  }
  // Progress line
  routeLines.forEach(l=>liveMap.removeLayer(l));
  routeLines=[];
  if (shipment?.originLat) {
    routeLines.push(
      L.polyline([[shipment.originLat,shipment.originLng],[lat,lng]],
        {color:'#FF5A36',weight:4,opacity:0.9}).addTo(liveMap)
    );
  }
  document.getElementById('mrCrVal').textContent = `${lat.toFixed(5)}, ${lng.toFixed(5)}`;
}

function animateMarker(mk, [toL,toG]) {
  const from = mk.getLatLng();
  const t0   = performance.now();
  const dur  = 1400;
  function step(now) {
    const p = Math.min(1,(now-t0)/dur);
    const e = p<.5 ? 2*p*p : -1+(4-2*p)*p;
    mk.setLatLng([from.lat+(toL-from.lat)*e, from.lng+(toG-from.lng)*e]);
    if(p<1) requestAnimationFrame(step);
  }
  requestAnimationFrame(step);
}

function fitAll(s) {
  if (!liveMap) return;
  const pts=[];
  if(s.originLat) pts.push([s.originLat,s.originLng]);
  if(s.courierLat) pts.push([s.courierLat,s.courierLng]);
  if(s.destLat) pts.push([s.destLat,s.destLng]);
  if(pts.length>=2) liveMap.fitBounds(L.latLngBounds(pts),{padding:[44,44]});
  else if(pts.length===1) liveMap.setView(pts[0],14);
}

// ─── Sheet UI ──────────────────────────────────────────────────────────────
function showSheet(s) {
  document.getElementById('sheet').style.display='block';
  document.getElementById('liveMap').style.display='block';
  document.getElementById('invalidScreen').style.display='none';

  document.getElementById('topProduct').textContent = s.product;
  document.getElementById('topCarrier').textContent = `${s.carrier} · ${s.tracking}`;
  document.getElementById('prodEmo').textContent    = s.emoji||'📦';
  document.getElementById('prodName').textContent   = s.product;
  document.getElementById('prodCarrier').textContent= s.carrier;
  document.getElementById('prodCode').textContent   = s.tracking;
  document.getElementById('productRow').style.display='flex';
  document.getElementById('mrOrVal').textContent    = s.originName||'—';
  document.getElementById('mrDtVal').textContent    = s.destName||'—';

  if (s.alert) {
    document.getElementById('alertBox').style.display='flex';
    document.getElementById('alertText').textContent = s.alert;
  } else {
    document.getElementById('alertBox').style.display='none';
  }

  updateStatus(s);
  refreshETA();
  clearInterval(etaTimer);
  etaTimer = setInterval(refreshETA, 30000);
}

function updateStatus(s) {
  const chip  = document.getElementById('liveChip');
  const cdot  = chip.querySelector('.cdot');
  const sdot  = document.getElementById('sdot');
  const main  = document.getElementById('stextMain');
  const sub   = document.getElementById('stextSub');
  const chipT = document.getElementById('chipTxt');

  sdot.className = 'sdot';

  if (s.currentStep===5) {
    sdot.classList.add('delivered');
    main.textContent='✓ Entrega completada';
    sub.textContent ='';
    chip.className='live-chip delivered';
    chipT.textContent='Entregado';
  } else if (s.courierActive && s.courierLat) {
    sdot.classList.add('active');
    const ago = timeAgo(s.positionUpdatedAt);
    main.textContent='Transportista en movimiento';
    sub.textContent =`GPS activo · última posición: ${ago}`;
    chip.className='live-chip active';
    chipT.textContent='GPS en vivo';
  } else if (s.courierLat) {
    sdot.classList.add('waiting');
    main.textContent='Transportista pausó el GPS';
    sub.textContent ='La última posición conocida se muestra en el mapa';
    chip.className='live-chip';
    chipT.textContent='GPS pausado';
  } else {
    sdot.classList.add('offline');
    main.textContent='Esperando al transportista…';
    sub.textContent ='El mapa se actualizará cuando el GPS esté activo';
    chip.className='live-chip';
    chipT.textContent='Sin GPS';
  }
}

// ─── WebSocket ─────────────────────────────────────────────────────────────
function connect() {
  if (!code) return;
  clearTimeout(reconnTimer);
  const proto = location.protocol==='https:' ? 'wss' : 'ws';
  ws = new WebSocket(`${proto}://${location.host}`);

  ws.onopen = () => {
    ws.send(JSON.stringify({type:'join', code}));
  };

  ws.onmessage = e => {
    let msg; try { msg=JSON.parse(e.data); } catch { return; }

    if (msg.type==='error') { showInvalid(); return; }

    if (msg.type==='state') {
      const first = !shipment;
      shipment = msg.shipment;
      showSheet(shipment);
      if (first) {
        initMap(shipment);
      } else {
        if (shipment.courierLat) placeCourier(shipment.courierLat, shipment.courierLng, false);
        fitAll(shipment);
      }
    }

    if (msg.type==='position') {
      if (!shipment) return;
      shipment.courierLat       = msg.lat;
      shipment.courierLng       = msg.lng;
      shipment.courierActive    = true;
      shipment.positionUpdatedAt= msg.updatedAt;
      placeCourier(msg.lat, msg.lng, false);
      updateStatus(shipment);
      refreshETA();
      // pan map gently to keep courier visible
      if (liveMap && markers.courier) {
        const b = liveMap.getBounds();
        if (!b.contains(markers.courier.getLatLng())) {
          liveMap.panTo(markers.courier.getLatLng(), {animate:true, duration:0.8});
        }
      }
    }

    if (msg.type==='courier_stop') {
      if (!shipment) return;
      shipment.courierActive = false;
      updateStatus(shipment);
    }
  };

  ws.onclose = () => { reconnTimer = setTimeout(connect, 4000); };
  ws.onerror = () => ws.close();
}

// ─── Courier GPS ───────────────────────────────────────────────────────────
const courierBtn = document.getElementById('courierBtn');

courierBtn.addEventListener('click', () => {
  if (courierSharing) stopGPS();
  else startGPS();
});

function startGPS() {
  if (!('geolocation' in navigator)) {
    toast('Tu dispositivo no soporta GPS');
    return;
  }
  courierBtn.disabled = true;
  courierBtn.textContent = 'Solicitando permiso de GPS…';

  watchId = navigator.geolocation.watchPosition(
    pos => {
      const {latitude:lat, longitude:lng, accuracy} = pos.coords;

      // Update map immediately
      placeCourier(lat, lng, false);
      if (shipment) {
        shipment.courierLat=lat; shipment.courierLng=lng;
        shipment.courierActive=true;
        shipment.positionUpdatedAt=new Date().toISOString();
        updateStatus(shipment);
        refreshETA();
      }

      // Send to server max every 3s
      const now = Date.now();
      if (now-lastSend < 3000) return;
      lastSend = now;
      if (ws && ws.readyState===WebSocket.OPEN) {
        ws.send(JSON.stringify({type:'position', code, lat, lng, accuracy}));
      }

      // Button state
      if (!courierSharing) {
        courierSharing = true;
        courierBtn.disabled = false;
        courierBtn.classList.add('sharing');
        courierBtn.innerHTML=`<svg viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s-8-6-8-11a8 8 0 1 1 16 0c0 5-8 11-8 11z"/><circle cx="12" cy="11" r="3"/></svg> GPS activo — Tocá para detener`;
        toast('📍 GPS activado. Todos pueden ver tu posición en tiempo real.');
      }
    },
    err => {
      courierBtn.disabled = false;
      courierBtn.innerHTML=`<svg viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s-8-6-8-11a8 8 0 1 1 16 0c0 5-8 11-8 11z"/><circle cx="12" cy="11" r="3"/></svg> Soy el transportista — Activar GPS`;
      const msgs = {1:'Permiso de GPS denegado. Habilitalo en ajustes del navegador.',2:'GPS no disponible en este momento.',3:'Tiempo de espera agotado. Intentá de nuevo.'};
      toast(msgs[err.code]||'No se pudo obtener el GPS.');
      courierSharing=false;
    },
    {enableHighAccuracy:true, maximumAge:2000, timeout:12000}
  );
}

function stopGPS() {
  if (watchId!==null) { navigator.geolocation.clearWatch(watchId); watchId=null; }
  courierSharing=false;
  if (ws && ws.readyState===WebSocket.OPEN) {
    ws.send(JSON.stringify({type:'courier_stop', code}));
  }
  if (shipment) { shipment.courierActive=false; updateStatus(shipment); }
  courierBtn.classList.remove('sharing');
  courierBtn.innerHTML=`<svg viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s-8-6-8-11a8 8 0 1 1 16 0c0 5-8 11-8 11z"/><circle cx="12" cy="11" r="3"/></svg> Soy el transportista — Activar GPS`;
  toast('GPS detenido.');
}

window.addEventListener('beforeunload', stopGPS);
window.addEventListener('pagehide', stopGPS);
window.addEventListener('resize', ()=>{ if(liveMap) liveMap.invalidateSize(); });

// ─── Start ─────────────────────────────────────────────────────────────────
if (code) connect();
</script>
</body>
</html>
